# Copy this file to .env and add your API keys

# Anthropic API Key for Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# N8n Integration (optional)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/github-issue-creator
N8N_API_KEY=your-n8n-api-key

# GitHub Integration (for n8n workflow)
GITHUB_REPOSITORY=owner/repo

# Note: You can also store API keys securely in your system keychain
# using the ENGIE settings interface once the app is running